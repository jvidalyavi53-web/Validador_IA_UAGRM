# ==============================================================================
# Validador IA UAGRM - Plantilla de variables de entorno
# Copia este archivo a .env y completa los valores.
# NUNCA commitees el archivo .env real.
# ==============================================================================

# --- OBLIGATORIAS ---
GROQ_API_KEY=
DATABASE_URL=sqlite:///./uagrm_enterprise.db
SECRET_KEY=

# --- ENTORNO ---
ENVIRONMENT=development
# production: aplica validaciones estrictas (SECRET_KEY obligatoria, etc.)
# development: tolera SECRET_KEY faltante con warning

# --- CORS ---
# Orígenes separados por coma. Ejemplo producción: https://tu-app.streamlit.app
ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# --- OCR (Tesseract) ---
# Solo Windows local. En Render se instala vía Aptfile.
TESSERACT_CMD=

# --- LÍMITES ---
GROQ_TIMEOUT=30
GROQ_MAX_RETRIES=2
MAX_UPLOAD_MB=50
MAX_REQUEST_SECONDS=50
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- CÓDIGO DE ADMINISTRADOR (para registro de admins) ---
ADMIN_SECRET=FICCT2026

# --- FRONTEND (configurar también en Streamlit Cloud > Secrets) ---
# API_URL=https://validador-ia-uagrm.onrender.com/api/v1
