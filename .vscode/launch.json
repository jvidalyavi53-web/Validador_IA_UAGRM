{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Ejecutar FastAPI (Backend)",
            "type": "python",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "backend.main:app",
                "--reload",
                "--port",
                "8000"
            ],
            "jinja": true,
            "justMyCode": true
        },
        {
            "name": "Ejecutar Streamlit (Frontend)",
            "type": "python",
            "request": "launch",
            "module": "streamlit",
            "args": [
                "run",
                "frontend/app.py"
            ],
            "justMyCode": true
        }
    ]
}